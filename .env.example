# Copy to .env before starting:
#     cp .env.example .env
#
# Compose reads .env automatically, so every command (up, down, logs) picks these
# up without extra flags.

# ---------------------------------------------------------------------------
# Where Ollama comes from
# ---------------------------------------------------------------------------
# "bundled" runs Ollama as part of this stack — the zero-setup default.
# If you already run Ollama yourself, delete this line and set OLLAMA_HOST below
# instead; nothing else changes.
COMPOSE_PROFILES=bundled

# Only needed when NOT using the bundled profile. Examples:
#   Ollama installed on this computer      http://host.docker.internal:11434
#   Ollama in another container (published) http://host.docker.internal:11434
#   Ollama on another machine               http://192.168.1.50:11434
# A host install must listen on 0.0.0.0 for the container to reach it — see the
# README's "Reuse an Ollama you already have" section.
#OLLAMA_HOST=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# Port the web app is served on: http://localhost:<SCANDY_PORT>
SCANDY_PORT=8080

# Model used for receipt scanning. qwen3.5:0.8b is the same model family the
# native MLX setup uses, is only ~1 GB, and reads date, time and total reliably.
OLLAMA_MODEL=qwen3.5:0.8b

# ---------------------------------------------------------------------------
# Scanning tuning (rarely needed)
# ---------------------------------------------------------------------------
# Context window. An image alone costs thousands of tokens, and Ollama's 4096
# default is not enough for a receipt photo.
OLLAMA_NUM_CTX=8192

# Longest image edge sent to the model. Token cost scales with image area, so
# this keeps large phone photos from overflowing the context. Raising it makes
# scans slower without reliably improving accuracy.
OLLAMA_MAX_IMAGE_EDGE=1280
